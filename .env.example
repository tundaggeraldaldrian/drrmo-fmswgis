# ============================================================
# SCDRRMO FMSWGIS — Environment Variables Template
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# .env is git-ignored and must NEVER be committed.
# ============================================================

# -------------------------------------------------------
# Django Core
# -------------------------------------------------------

# Generate a strong random key for production:
#   python -c "import secrets; print('django-' + secrets.token_hex(25))"
SECRET_KEY=django-replace-this-with-a-strong-random-key

# Set to False in production
DEBUG=False

# Set to True ONLY after SSL certificates are installed in Nginx.
# Enables SESSION_COOKIE_SECURE, CSRF_COOKIE_SECURE, and HSTS headers.
# Leaving False lets the system run over plain HTTP (e.g. initial deployment).
HTTPS_ENABLED=False

# -------------------------------------------------------
# Allowed Hosts & CSRF
# Comma-separated — add your server IP or domain here
# -------------------------------------------------------
ALLOWED_HOSTS=localhost,127.0.0.1

# Must include the full URL (scheme + host) of your deployment
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# -------------------------------------------------------
# Database (PostgreSQL + PostGIS)
# -------------------------------------------------------
DB_NAME=silaydrrmo_db
DB_USER=postgres
DB_PASSWORD=replace-with-strong-db-password
# When running with Docker Compose, use 'db' (the service name)
# When running locally without Docker, use 'localhost'
DB_HOST=db
DB_PORT=5432

# -------------------------------------------------------
# External APIs
# -------------------------------------------------------

# WorldTides API — tide level data for Cebu reference station
# Register at: https://www.worldtides.info/developer
WORLDTIDES_API_KEY=your-worldtides-api-key-here

# -------------------------------------------------------
# Admin Registration
# Key required to create the first admin account via /register/admin/
# Use any strong random string
# -------------------------------------------------------
ADMIN_REGISTRATION_KEY=choose-a-secure-admin-registration-key

# -------------------------------------------------------
# Gunicorn (optional — defaults shown)
# -------------------------------------------------------
# Number of worker processes. Rule: (2 * CPU_cores) + 1
# GUNICORN_WORKERS=3

# -------------------------------------------------------
# GIS Library Paths (optional — only override if non-standard)
# Defaults work on Ubuntu 22.04/24.04 and Debian Bookworm x86_64
# -------------------------------------------------------
# GDAL_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu/libgdal.so
# GEOS_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu/libgeos_c.so
