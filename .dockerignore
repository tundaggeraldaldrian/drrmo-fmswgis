# ============================================================
# .dockerignore — Files excluded from the Docker build context
# Keeps the image small and prevents secrets from leaking in
# ============================================================

# Python venv (not needed — Docker installs deps fresh from requirements.txt)
env-drrmo/
venv/
env/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Django generated files (created fresh inside the container)
staticfiles/
db.sqlite3

# Logs (mounted as a volume)
logs/
*.log

# Environment file (secrets must NOT be baked into the image)
.env

# Node modules
node_modules/
package-lock.json

# Git
.git/
.gitignore

# IDE / OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Test files and coverage reports
.coverage
htmlcov/
.pytest_cache/

# Docs and plan files
*.md
.windsurf/

# Nginx SSL certs (mounted as volume, not baked in)
nginx/certs/
